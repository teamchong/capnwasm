{
  "name": "capnwasm",
  "version": "0.0.1",
  "description": "Real Cap'n Proto C++ compiled to wasm + npx CLI for typed JS bindings",
  "type": "module",
  "main": "js/index.mjs",
  "exports": {
    ".":            "./js/index.mjs",
    "./inlined":    "./dist/inlined.mjs",
    "./cpp_loader": "./js/cpp_loader.mjs",
    "./tape_codec": "./js/tape_codec.mjs"
  },
  "bin": {
    "capnwasm": "./bin/capnwasm.mjs"
  },
  "files": [
    "js",
    "bin",
    "dist",
    "zig-out/capnp_cpp.opt.wasm"
  ],
  "scripts": {
    "build:wasm": "bash cpp/build.sh",
    "bench":      "node bench/runner.mjs",
    "test":       "node --test test/*.test.mjs"
  },
  "license": "MIT",
  "devDependencies": {
    "playwright": "^1.56.1"
  }
}
