{
  "name": "capnwasm",
  "main": "src/worker.mjs",
  "compatibility_date": "2026-05-02",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    {
      "pattern": "capnwasm.teamchong.net",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./web/dist",
    "binding": "ASSETS",
    "run_worker_first": false,
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true
  }
}
