{
  "name": "capnwasm",
  "main": "src/worker.mjs",
  "compatibility_date": "2026-05-02",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    {
      "pattern": "capnwasm.teamchong.net",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./web/dist",
    "binding": "ASSETS",
    "run_worker_first": false,
    "not_found_handling": "404-page"
  },
  "durable_objects": {
    "bindings": [
      { "name": "CHAT_ROOM", "class_name": "ChatRoom" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ChatRoom"] }
  ],
  "observability": {
    "enabled": true
  }
}
